// Accounting Firm Portal — Prisma schema.
//
// Phase 0 covers the CORE identity, access & tenancy entities from
// docs/system-design.md §7.1 (View A). Financial, tax and BIR-integration
// entities (View B) arrive in later phases.
//
// Design notes:
//   * The domain model's abstract `User` (with `FirmUser` / `ClientUser`
//     subclasses) is expressed as a single `User` table + a `userType`
//     discriminator + one profile table per subtype. Prisma has no class
//     inheritance, and a single table keeps auth/RBAC joins uniform.
//   * Tax-classification enums are OWNED by @portal/shared and must never be
//     re-declared here. Only DB-structural enums live in this file.
//   * Every tenant-scoped row carries firmId / clientId for isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Structural enums (NOT tax-classification; those live in @portal/shared) ---

enum UserType {
  FIRM
  CLIENT
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum ClientStatus {
  ACTIVE
  ARCHIVED
}

/// Scope of a role: firm-wide staff roles vs. client-portal roles.
enum RoleScope {
  FIRM
  CLIENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum IntegrationClientStatus {
  ACTIVE
  DISABLED
}

/// Whether a category applies to income/sales or expense/purchase records.
enum CategoryType {
  INCOME
  EXPENSE
}

/// How the firm bills a client for its services (engagement billing cadence).
enum BillingMethod {
  QUARTERLY
  MONTHLY
  AS_FILING
}

// --- Tenancy root ---

/// The accounting firm operating the portal (top-level tenant owner).
model Firm {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  settingsJson Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clients            Client[]
  users              User[]
  integrationClients IntegrationClient[]
  services           Service[]

  @@map("firms")
}

/// A business served by the firm. Each client is an isolated data tenant.
///
/// Mirrors the BIR "filer" profile captured in the Sentire tax app (so a client
/// maps 1:1 onto a Sentire Taxpayer — the Portal is the system of record and
/// Sentire refreshes from it), PLUS two firm-only engagement fields
/// (professionalFee, billingMethod) that are never exported to the BIR forms.
model Client {
  id              String       @id @default(uuid()) @db.Uuid
  firmId          String       @db.Uuid
  businessName    String // canonical display name (regName for a company)
  tin             String?
  address         String?
  taxType         String? // "VAT" | "PERCENTAGE" — the aggregation regime
  fiscalYearStart DateTime?    @db.Date
  currency        String       @default("PHP")
  seatLimit       Int          @default(3) // FR-17: minimum 3 seats per client
  status          ClientStatus @default(ACTIVE)

  // --- BIR filer profile (replicates Sentire's Add Filer) ------------------
  kind           String  @default("non-individual") // "individual" | "non-individual"
  regName        String? // BIR registered name (company)
  lastName       String? // individual
  firstName      String?
  middleName     String?
  tradeName      String?
  branch         String  @default("00000")
  rdo            String? // RDO code
  rdoName        String?
  city           String?
  zip            String?
  birthdate      DateTime? @db.Date // individual
  incorpDate     DateTime? @db.Date // company
  email          String?
  phone          String?
  citizenship    String?
  civilStatus    String?
  taxpayerType   String?
  classification String?
  /// Registration lines from the COR "Tax Types" table:
  /// [{ type, form, frequency, startDate }]. Owned by @portal/shared shape.
  taxTypesJson   Json    @default("[]")
  /// S3 object key of the uploaded COR file (`<firmId>/<clientId>`), or null
  /// when no COR has been stored. The file lives in S3-compatible object storage.
  corPath        String?

  // --- Firm engagement (Portal-only; NOT sent to the BIR Generator) --------
  professionalFee Decimal?      @db.Decimal(18, 2) // fee the firm charges
  billingMethod   BillingMethod @default(AS_FILING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm                 Firm                   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientUsers          ClientUserProfile[]
  assignedStaff        FirmClientAssignment[]
  invitations          Invitation[]
  scopedUserRoles      UserRole[]
  categories           Category[]
  incomeTransactions   IncomeTransaction[]
  purchaseTransactions PurchaseTransaction[]
  birFilings           BIRFiling[]
  inputTaxAssets       InputTaxAsset[]
  taxRule              TaxRule?

  @@index([firmId])
  @@map("clients")
}

// --- Users (single table + discriminator + profile tables) ---

/// Base account for every human user (firm staff and client-portal users).
model User {
  id           String     @id @default(uuid()) @db.Uuid
  firmId       String     @db.Uuid
  userType     UserType
  fullName     String
  email        String     @unique
  passwordHash String?
  mfaEnabled   Boolean    @default(false)
  /// Base32 TOTP secret. Set at enrollment; MFA is only enforced once mfaEnabled=true.
  /// NOTE: encrypt at rest in production; stored plain here for the reference build.
  mfaSecret    String?
  status       UserStatus @default(INVITED)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  firm          Firm               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  firmProfile   FirmUserProfile?
  clientProfile ClientUserProfile?
  userRoles     UserRole[]
  auditLogs     AuditLog[]

  @@index([firmId])
  @@map("users")
}

/// Firm-staff specific attributes (User.userType = FIRM).
model FirmUserProfile {
  userId     String  @id @db.Uuid
  title      String?
  employeeId String?

  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientAssignments FirmClientAssignment[]

  @@map("firm_user_profiles")
}

/// Client-portal specific attributes (User.userType = CLIENT).
model ClientUserProfile {
  userId     String @id @db.Uuid
  clientId   String @db.Uuid
  clientRole String // "OWNER" | "MANAGER" | "VIEWER" — enforced in Phase 1

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_user_profiles")
}

/// Assignment of a firm user to a client (per-client visibility scoping).
model FirmClientAssignment {
  firmUserId String @db.Uuid
  clientId   String @db.Uuid

  firmUser FirmUserProfile @relation(fields: [firmUserId], references: [userId], onDelete: Cascade)
  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([firmUserId, clientId])
  @@index([clientId])
  @@map("firm_client_assignments")
}

// --- RBAC (data-driven roles & permissions) ---

model Role {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  scope     RoleScope
  createdAt DateTime  @default(now())

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([name, scope])
  @@map("roles")
}

/// A granular (resource, action) permission, e.g. Sales:Create.
model Permission {
  id       String @id @default(uuid()) @db.Uuid
  resource String
  action   String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

/// Grant of a role to a user, optionally scoped to a single client
/// (clientScopeId null = firm-wide / not client-scoped).
model UserRole {
  id            String  @id @default(uuid()) @db.Uuid
  userId        String  @db.Uuid
  roleId        String  @db.Uuid
  clientScopeId String? @db.Uuid

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  clientScope Client? @relation(fields: [clientScopeId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, clientScopeId])
  @@index([userId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// --- Invitations, integration credentials, audit ---

/// Client-user invitation with a single-use, expiring activation token (FR-04).
model Invitation {
  id        String           @id @default(uuid()) @db.Uuid
  email     String
  clientId  String           @db.Uuid
  role      String
  token     String           @unique
  expiresAt DateTime
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("invitations")
}

/// OAuth2 client-credentials machine credential for the BIR Form Generator.
/// Secret is stored HASHED; granted scopes are a JSON array of OAuthScope.
model IntegrationClient {
  id                String                  @id @default(uuid()) @db.Uuid
  firmId            String                  @db.Uuid
  clientKey         String                  @unique
  clientSecretHash  String
  grantedScopesJson Json                    @default("[]")
  status            IntegrationClientStatus @default(ACTIVE)
  lastUsedAt        DateTime?
  createdAt         DateTime                @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@map("integration_clients")
}

/// Append-only audit trail (FR-32).
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  action     String
  entityType String
  entityId   String?  @db.Uuid
  ipAddress  String?
  metadata   Json     @default("{}")
  timestamp  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Phase 2 — Financial data & capture (system-design §7.2 View B).
//
// Tax-classification enums (VatClass, InputVATCategory, InputTaxAttribution) are
// FROZEN and owned by @portal/shared; they are stored here as String columns and
// validated against the shared Zod enums — never re-declared as Prisma enums
// (guardrail #2). Money is stored NET OF VAT with VAT carried in its own columns
// (guardrail #3); Decimal(18,2) avoids float drift.
// ---------------------------------------------------------------------------

/// A per-client reporting/deductibility bucket for income or expense records.
model Category {
  id           String       @id @default(uuid()) @db.Uuid
  clientId     String       @db.Uuid
  type         CategoryType
  name         String
  isDeductible Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  incomeTransactions   IncomeTransaction[]
  purchaseTransactions PurchaseTransaction[]

  @@unique([clientId, type, name])
  @@index([clientId])
  @@map("categories")
}

/// SalesRecord + IncomeTransaction (§7.2): a sales/income row classified for VAT
/// at capture. `netAmount` is net of VAT; `vatClass` is a @portal/shared VatClass.
model IncomeTransaction {
  id                        String   @id @default(uuid()) @db.Uuid
  clientId                  String   @db.Uuid
  categoryId                String   @db.Uuid
  txnDate                   DateTime @db.Date
  referenceNo               String?
  customer                  String?
  description               String
  netAmount                 Decimal  @db.Decimal(18, 2)
  vatClass                  String // VatClass (@portal/shared)
  saleToGovernment          Boolean  @default(false)
  outputVAT                 Decimal? @db.Decimal(18, 2) // advisory; Generator derives 12% × net
  creditableVATWithheld5pct Decimal? @db.Decimal(18, 2)
  atc                       String?
  source                    String   @default("manual") // TransactionSource: manual | import
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([clientId, txnDate])
  @@index([clientId, vatClass]) // sum-by-vatClass aggregation (Phase 6 vat-summary)
  @@index([categoryId])
  @@map("income_transactions")
}

/// ExpenseRecord + PurchaseTransaction (§7.2): an expense/purchase row classified
/// for input-VAT treatment at capture. `netAmount` is net of VAT.
model PurchaseTransaction {
  id                         String   @id @default(uuid()) @db.Uuid
  clientId                   String   @db.Uuid
  categoryId                 String   @db.Uuid
  txnDate                    DateTime @db.Date
  referenceNo                String?
  vendor                     String?
  description                String
  netAmount                  Decimal  @db.Decimal(18, 2)
  inputVATCategory           String? // InputVATCategory (@portal/shared)
  inputVAT                   Decimal? @db.Decimal(18, 2)
  isCapitalGood              Boolean  @default(false)
  capitalGoodAcquisitionCost Decimal? @db.Decimal(18, 2)
  estimatedUsefulLifeMonths  Int?
  inputTaxAttribution        String? // InputTaxAttribution (@portal/shared)
  deductible                 Boolean  @default(true)
  source                     String   @default("manual")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([clientId, txnDate])
  @@index([clientId, inputVATCategory]) // sum-by-category aggregation (Phase 6 vat-summary)
  @@index([categoryId])
  @@map("purchase_transactions")
}

// ---------------------------------------------------------------------------
// Phase 6/7 — BIR Form Generator integration (write-back targets).
//
// These rows are written by the INTEGRATION (the Generator's push-back), never
// by portal users. Guardrail #1: the Portal does not compute authoritative BIR
// tax — it only RECORDS the filed artifact and the carried-forward Input Tax
// Asset the Generator hands back. Guardrail #4: push-back is idempotent, keyed
// by client + form + period (upsert, never duplicate).
//
// Enums (FormCode, FilingStatus, PeriodType) are OWNED by @portal/shared and
// stored here as String columns validated against the shared Zod enums.
// ---------------------------------------------------------------------------

/// A finished BIR filing pushed back by the Generator (status + eBIRForms XML + PDF).
model BIRFiling {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @db.Uuid
  form        String // FormCode (@portal/shared), e.g. "2550Q"
  periodType  String // PeriodType (@portal/shared)
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  status      String // FilingStatus (@portal/shared): draft | ready | filed
  figuresJson Json     @default("{}") // per-form key figures (may be negative)
  xmlFilename String
  xmlBase64   String   @db.Text
  pdfUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Guardrail #4: idempotency key — a re-sync of the same period UPDATES in place.
  @@unique([clientId, form, periodStart, periodEnd])
  @@index([clientId])
  @@map("bir_filings")
}

/// The carried-forward creditable input VAT the Generator books back as an asset.
model InputTaxAsset {
  id                           String   @id @default(uuid()) @db.Uuid
  clientId                     String   @db.Uuid
  sourceForm                   String // FormCode (@portal/shared)
  asOfYear                     Int
  asOfQuarter                  Int
  excessInputTaxCarriedForward Decimal  @db.Decimal(18, 2)
  deferredCapitalGoodsInputTax Decimal  @db.Decimal(18, 2)
  totalInputTaxAsset           Decimal  @db.Decimal(18, 2)
  computedAt                   DateTime
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // One booked asset per client + source form + period (re-send updates it).
  @@unique([clientId, sourceForm, asOfYear, asOfQuarter])
  @@index([clientId])
  @@map("input_tax_assets")
}

/// A firm's service-offering catalog (Portal-only; not part of the BIR contract).
/// Firm-scoped and managed by Firm/Super Admins. `linkedForm` is an optional
/// FormCode (@portal/shared) that associates the service with a BIR form.
model Service {
  id            String   @id @default(uuid()) @db.Uuid
  firmId        String   @db.Uuid
  name          String
  description   String   @default("")
  defaultFee    Decimal  @default(0) @db.Decimal(18, 2)
  billingMethod String // "Quarterly" | "Monthly" | "As Filing"
  linkedForm    String? // FormCode (@portal/shared) or null
  status        String   @default("Active") // "Active" | "Retired"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@map("services")
}

/// Per-client income-tax computation configuration (Portal MANAGEMENT ESTIMATE
/// only — NOT authoritative BIR tax; guardrail #1). Exactly one row per client.
/// `method` selects the regime ("graduated" | "flat" | "percentage" |
/// "simplified8"); `bracketsJson` holds the graduated schedule as an array of
/// { over, notOver, baseTax, rate }; `flatRate` is the single rate % used by the
/// non-graduated methods. When no row exists the API serves the TRAIN graduated
/// default without persisting it.
model TaxRule {
  id           String   @id @default(uuid()) @db.Uuid
  clientId     String   @unique @db.Uuid
  method       String // "graduated" | "flat" | "percentage" | "simplified8"
  flatRate     Decimal? @db.Decimal(6, 3) // single rate % for non-graduated methods
  bracketsJson Json     @default("[]") // [{ over, notOver, baseTax, rate }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("tax_rules")
}
