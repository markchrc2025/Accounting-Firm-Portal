// Accounting Firm Portal — Prisma schema.
//
// Phase 0 covers the CORE identity, access & tenancy entities from
// docs/system-design.md §7.1 (View A). Financial, tax and BIR-integration
// entities (View B) arrive in later phases.
//
// Design notes:
//   * The domain model's abstract `User` (with `FirmUser` / `ClientUser`
//     subclasses) is expressed as a single `User` table + a `userType`
//     discriminator + one profile table per subtype. Prisma has no class
//     inheritance, and a single table keeps auth/RBAC joins uniform.
//   * Tax-classification enums are OWNED by @portal/shared and must never be
//     re-declared here. Only DB-structural enums live in this file.
//   * Every tenant-scoped row carries firmId / clientId for isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Structural enums (NOT tax-classification; those live in @portal/shared) ---

enum UserType {
  FIRM
  CLIENT
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum ClientStatus {
  ACTIVE
  ARCHIVED
}

/// Scope of a role: firm-wide staff roles vs. client-portal roles.
enum RoleScope {
  FIRM
  CLIENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum IntegrationClientStatus {
  ACTIVE
  DISABLED
}

/// Whether a category applies to income/sales or expense/purchase records.
enum CategoryType {
  INCOME
  EXPENSE
}

/// How the firm bills a client for its services (engagement billing cadence).
enum BillingMethod {
  QUARTERLY
  MONTHLY
  AS_FILING
}

// --- Tenancy root ---

/// The accounting firm operating the portal (top-level tenant owner).
model Firm {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  settingsJson Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clients            Client[]
  users              User[]
  integrationClients IntegrationClient[]
  services           Service[]
  invoices           Invoice[]

  @@map("firms")
}

/// A business served by the firm. Each client is an isolated data tenant.
///
/// Mirrors the BIR "filer" profile captured in the Sentire tax app (so a client
/// maps 1:1 onto a Sentire Taxpayer — the Portal is the system of record and
/// Sentire refreshes from it), PLUS two firm-only engagement fields
/// (professionalFee, billingMethod) that are never exported to the BIR forms.
model Client {
  id              String       @id @default(uuid()) @db.Uuid
  firmId          String       @db.Uuid
  businessName    String // canonical display name (regName for a company)
  tin             String?
  address         String?
  taxType         String? // "VAT" | "PERCENTAGE" — the aggregation regime
  fiscalYearStart DateTime?    @db.Date
  currency        String       @default("PHP")
  seatLimit       Int          @default(3) // FR-17: minimum 3 seats per client
  status          ClientStatus @default(ACTIVE)

  // --- BIR filer profile (replicates Sentire's Add Filer) ------------------
  kind           String  @default("non-individual") // "individual" | "non-individual"
  regName        String? // BIR registered name (company)
  lastName       String? // individual
  firstName      String?
  middleName     String?
  tradeName      String?
  branch         String  @default("00000")
  rdo            String? // RDO code
  rdoName        String?
  city           String?
  province       String?
  region         String?
  zip            String?
  birthdate      DateTime? @db.Date // individual
  incorpDate     DateTime? @db.Date // company
  email          String?
  phone          String?
  citizenship    String?
  civilStatus    String?
  taxpayerType   String?
  classification String?
  /// Registration lines from the COR "Tax Types" table:
  /// [{ type, form, frequency, startDate }]. Owned by @portal/shared shape.
  taxTypesJson   Json    @default("[]")
  /// Whether this client is registered with branches (same TIN, branch codes).
  hasBranches    Boolean @default(false)
  /// Branch offices (each its own COR / branch code):
  /// [{ branchCode, tradeName, address, city, province, region, zip, rdo }].
  branchesJson   Json    @default("[]")
  /// S3 object key of the uploaded COR file (`<firmId>/<clientId>`), or null
  /// when no COR has been stored. The file lives in S3-compatible object storage.
  corPath        String?

  // --- Firm engagement (Portal-only; NOT sent to the BIR Generator) --------
  professionalFee Decimal?      @db.Decimal(18, 2) // fee the firm charges
  billingMethod   BillingMethod @default(AS_FILING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm                 Firm                   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientUsers          ClientUserProfile[]
  assignedStaff        FirmClientAssignment[]
  invitations          Invitation[]
  scopedUserRoles      UserRole[]
  categories           Category[]
  incomeTransactions   IncomeTransaction[]
  purchaseTransactions PurchaseTransaction[]
  birFilings           BIRFiling[]
  inputTaxAssets       InputTaxAsset[]
  taxRule              TaxRule?
  invoices             Invoice[]

  @@index([firmId])
  @@map("clients")
}

// --- Users (single table + discriminator + profile tables) ---

/// Base account for every human user (firm staff and client-portal users).
model User {
  id           String     @id @default(uuid()) @db.Uuid
  firmId       String     @db.Uuid
  userType     UserType
  fullName     String
  email        String     @unique
  passwordHash String?
  mfaEnabled   Boolean    @default(false)
  /// Base32 TOTP secret. Set at enrollment; MFA is only enforced once mfaEnabled=true.
  /// NOTE: encrypt at rest in production; stored plain here for the reference build.
  mfaSecret    String?
  status       UserStatus @default(INVITED)
  /// Object-storage key of the user's uploaded avatar (S3-compatible); null when unset.
  avatarPath   String?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  firm          Firm               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  firmProfile   FirmUserProfile?
  clientProfile ClientUserProfile?
  userRoles     UserRole[]
  auditLogs     AuditLog[]

  @@index([firmId])
  @@map("users")
}

/// Firm-staff specific attributes (User.userType = FIRM).
model FirmUserProfile {
  userId     String  @id @db.Uuid
  title      String?
  employeeId String?

  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientAssignments FirmClientAssignment[]

  @@map("firm_user_profiles")
}

/// Client-portal specific attributes (User.userType = CLIENT).
model ClientUserProfile {
  userId     String @id @db.Uuid
  clientId   String @db.Uuid
  clientRole String // "OWNER" | "MANAGER" | "VIEWER" — enforced in Phase 1

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_user_profiles")
}

/// Assignment of a firm user to a client (per-client visibility scoping).
model FirmClientAssignment {
  firmUserId String @db.Uuid
  clientId   String @db.Uuid

  firmUser FirmUserProfile @relation(fields: [firmUserId], references: [userId], onDelete: Cascade)
  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([firmUserId, clientId])
  @@index([clientId])
  @@map("firm_client_assignments")
}

// --- RBAC (data-driven roles & permissions) ---

model Role {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  scope     RoleScope
  createdAt DateTime  @default(now())

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([name, scope])
  @@map("roles")
}

/// A granular (resource, action) permission, e.g. Sales:Create.
model Permission {
  id       String @id @default(uuid()) @db.Uuid
  resource String
  action   String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

/// Grant of a role to a user, optionally scoped to a single client
/// (clientScopeId null = firm-wide / not client-scoped).
model UserRole {
  id            String  @id @default(uuid()) @db.Uuid
  userId        String  @db.Uuid
  roleId        String  @db.Uuid
  clientScopeId String? @db.Uuid

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  clientScope Client? @relation(fields: [clientScopeId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, clientScopeId])
  @@index([userId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// --- Invitations, integration credentials, audit ---

/// Client-user invitation with a single-use, expiring activation token (FR-04).
model Invitation {
  id        String           @id @default(uuid()) @db.Uuid
  email     String
  clientId  String           @db.Uuid
  role      String
  token     String           @unique
  expiresAt DateTime
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("invitations")
}

/// OAuth2 client-credentials machine credential for the BIR Form Generator.
/// Secret is stored HASHED; granted scopes are a JSON array of OAuthScope.
model IntegrationClient {
  id                String                  @id @default(uuid()) @db.Uuid
  firmId            String                  @db.Uuid
  name              String                  @default("")
  clientKey         String                  @unique
  clientSecretHash  String
  grantedScopesJson Json                    @default("[]")
  status            IntegrationClientStatus @default(ACTIVE)
  lastUsedAt        DateTime?
  createdAt         DateTime                @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@map("integration_clients")
}

/// Append-only audit trail (FR-32).
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  action     String
  entityType String
  entityId   String?  @db.Uuid
  ipAddress  String?
  metadata   Json     @default("{}")
  timestamp  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Phase 2 — Financial data & capture (system-design §7.2 View B).
//
// Tax-classification enums (VatClass, InputVATCategory, InputTaxAttribution) are
// FROZEN and owned by @portal/shared; they are stored here as String columns and
// validated against the shared Zod enums — never re-declared as Prisma enums
// (guardrail #2). Money is stored NET OF VAT with VAT carried in its own columns
// (guardrail #3); Decimal(18,2) avoids float drift.
// ---------------------------------------------------------------------------

/// A per-client reporting/deductibility bucket for income or expense records.
model Category {
  id           String       @id @default(uuid()) @db.Uuid
  clientId     String       @db.Uuid
  type         CategoryType
  name         String
  isDeductible Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  incomeTransactions   IncomeTransaction[]
  purchaseTransactions PurchaseTransaction[]

  @@unique([clientId, type, name])
  @@index([clientId])
  @@map("categories")
}

/// SalesRecord + IncomeTransaction (§7.2): a sales/income row classified for VAT
/// at capture. `netAmount` is net of VAT; `vatClass` is a @portal/shared VatClass.
model IncomeTransaction {
  id                        String   @id @default(uuid()) @db.Uuid
  clientId                  String   @db.Uuid
  categoryId                String   @db.Uuid
  txnDate                   DateTime @db.Date
  referenceNo               String?
  customer                  String?
  description               String
  netAmount                 Decimal  @db.Decimal(18, 2)
  vatClass                  String // VatClass (@portal/shared)
  saleToGovernment          Boolean  @default(false)
  outputVAT                 Decimal? @db.Decimal(18, 2) // advisory; Generator derives 12% × net
  creditableVATWithheld5pct Decimal? @db.Decimal(18, 2)
  atc                       String?
  source                    String   @default("manual") // TransactionSource: manual | import
  // Invoice-style line metadata (additive; netAmount stays authoritative).
  customerTin               String?
  dueDate                   DateTime? @db.Date
  terms                     String?
  account                   String?
  unit                      String?
  quantity                  Decimal? @db.Decimal(18, 4)
  unitPrice                 Decimal? @db.Decimal(18, 2)
  discount                  Decimal? @db.Decimal(18, 2)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([clientId, txnDate])
  @@index([clientId, vatClass]) // sum-by-vatClass aggregation (Phase 6 vat-summary)
  @@index([categoryId])
  @@map("income_transactions")
}

/// ExpenseRecord + PurchaseTransaction (§7.2): an expense/purchase row classified
/// for input-VAT treatment at capture. `netAmount` is net of VAT.
model PurchaseTransaction {
  id                         String   @id @default(uuid()) @db.Uuid
  clientId                   String   @db.Uuid
  categoryId                 String   @db.Uuid
  txnDate                    DateTime @db.Date
  referenceNo                String?
  vendor                     String?
  description                String
  netAmount                  Decimal  @db.Decimal(18, 2)
  inputVATCategory           String? // InputVATCategory (@portal/shared)
  inputVAT                   Decimal? @db.Decimal(18, 2)
  isCapitalGood              Boolean  @default(false)
  capitalGoodAcquisitionCost Decimal? @db.Decimal(18, 2)
  estimatedUsefulLifeMonths  Int?
  inputTaxAttribution        String? // InputTaxAttribution (@portal/shared)
  deductible                 Boolean  @default(true)
  source                     String   @default("manual")
  // Bill-style line metadata (additive). atc = withholding/Tax Code.
  vendorTin                  String?
  dueDate                    DateTime? @db.Date
  account                    String?
  atc                        String?
  taxAmount                  Decimal? @db.Decimal(18, 2)
  unit                       String?
  quantity                   Decimal? @db.Decimal(18, 4)
  unitPrice                  Decimal? @db.Decimal(18, 2)
  discount                   Decimal? @db.Decimal(18, 2)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([clientId, txnDate])
  @@index([clientId, inputVATCategory]) // sum-by-category aggregation (Phase 6 vat-summary)
  @@index([categoryId])
  @@map("purchase_transactions")
}

// ---------------------------------------------------------------------------
// BIR tax-code reference data (global; national codes, not per-firm). Seeded
// idempotently from prisma/data/bir_tax_codes.json (RMO 42-2003, RR 2-98 as
// amended by RR 11-2018, RR 4-2021, BIR Forms 2550/1603Q). Reference data —
// updatable as revenue issuances change; see docs HANDOFF.
// ---------------------------------------------------------------------------

/// A BIR registration tax type (the 2-letter code on Form 2303), e.g. VT, IT.
model BirTaxType {
  code   String   @id
  name   String
  forms  String[] @default([]) // returns this tax type must file (e.g. ["2550M","2550Q"])
  status String   @default("active") // active | repealed
  notes  String?

  @@map("bir_tax_types")
}

/// A BIR Alphanumeric Tax Code (ATC) — a transaction-level withholding/VAT code.
model BirAtcCode {
  atc             String   @id
  classification  String // vat | ewt | fwt | wvat | percentage_wt
  taxTypeCode     String // FK-by-value → BirTaxType.code
  payeeType       String // individual | corporation | employee | any
  description     String
  condition       String?
  rate            Decimal? @db.Decimal(12, 6) // decimal fraction (0.05 = 5%)
  rateBasis       String?
  thresholdAmount Decimal? @db.Decimal(18, 2)
  bracket         String? // at_or_below | above
  forms           String[] @default([])
  certificate     String? // 2307 (creditable) | 2306 (final)
  status          String   @default("active") // active | legacy | repealed
  notes           String?

  @@index([classification])
  @@index([taxTypeCode])
  @@index([status])
  @@map("bir_atc_codes")
}

// ---------------------------------------------------------------------------
// PH SME Chart of Accounts + BIR income-tax mapping (global reference data).
// Seeded idempotently from prisma/data/Chart_of_Accounts_Import.xlsx and
// prisma/data/BIR_Income_Tax_Mapping.xlsx — the xlsx files are the single
// source of truth; account lists are never hardcoded. Parsing, derivation and
// convention validation live in src/coa/coa-import.ts.
// ---------------------------------------------------------------------------

/// A posting account in the standard PH SME chart of accounts.
model ChartAccount {
  code            String    @id // 4-digit top-level, or 7-digit sub-account
  name            String
  class           String // Asset | Liability | Equity | Revenue | Expense
  accountType     String // Bank Accounts | Current Asset | ... | Other Expense
  /// Authoritative parent code from CoA_Hierarchy.xlsx (null = top-level). It may
  /// point at a group header or a postable account; NOT derived from the prefix
  /// and NOT a foreign key (headers and accounts share this table).
  parentCode      String?
  /// Derived: debit | credit. Asset/Expense = debit, Liability/Equity/Revenue =
  /// credit — except the contra accounts (1901001, 1902001 credit; 3901001 debit).
  normalBalance   String
  currency        String    @default("PHP")
  lockDate        DateTime? @db.Date
  monthlyMovement Boolean   @default(false)
  description     String?
  /// Group headers (postable = false) organise the chart but take no journal
  /// lines and are excluded from the postable account list + P&L coverage.
  postable        Boolean   @default(true)
  /// "seed" rows come from the xlsx; "custom" rows were created in-app.
  source          String    @default("custom")
  /// Set on any in-app edit — the seeder skips edited rows so user changes
  /// survive redeploys (the xlsx only drives untouched rows).
  editedAt        DateTime?
  /// Soft delete: archived accounts stay for history but leave pickers.
  archived        Boolean   @default(false)

  @@index([class])
  @@index([parentCode])
  @@map("chart_accounts")
}

/// BIR 1701/1702 itemized-deduction line mapping for a P&L posting account.
/// `taxReturnLine` NULL is INTENTIONAL for 4001 / 4002 (Cost of Sales section)
/// and 5008 (below the line) — the allowed-unmapped set.
model AccountTaxMapping {
  accountCode   String
  taxCategory   String    @default("Regular")
  accountName   String
  taxReturnLine String?
  source        String    @default("custom")
  editedAt      DateTime?

  @@id([accountCode, taxCategory])
  @@map("account_tax_mappings")
}

// ---------------------------------------------------------------------------
// Phase 6/7 — BIR Form Generator integration (write-back targets).
//
// These rows are written by the INTEGRATION (the Generator's push-back), never
// by portal users. Guardrail #1: the Portal does not compute authoritative BIR
// tax — it only RECORDS the filed artifact and the carried-forward Input Tax
// Asset the Generator hands back. Guardrail #4: push-back is idempotent, keyed
// by client + form + period (upsert, never duplicate).
//
// Enums (FormCode, FilingStatus, PeriodType) are OWNED by @portal/shared and
// stored here as String columns validated against the shared Zod enums.
// ---------------------------------------------------------------------------

/// A finished BIR filing pushed back by the Generator (status + eBIRForms XML + PDF).
model BIRFiling {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @db.Uuid
  form        String // FormCode (@portal/shared), e.g. "2550Q"
  periodType  String // PeriodType (@portal/shared)
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  status      String // FilingStatus (@portal/shared): draft | ready | filed
  figuresJson Json     @default("{}") // per-form key figures (may be negative)
  xmlFilename String
  xmlBase64   String   @db.Text
  pdfUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Guardrail #4: idempotency key — a re-sync of the same period UPDATES in place.
  @@unique([clientId, form, periodStart, periodEnd])
  @@index([clientId])
  @@map("bir_filings")
}

/// The carried-forward creditable input VAT the Generator books back as an asset.
model InputTaxAsset {
  id                           String   @id @default(uuid()) @db.Uuid
  clientId                     String   @db.Uuid
  sourceForm                   String // FormCode (@portal/shared)
  asOfYear                     Int
  asOfQuarter                  Int
  excessInputTaxCarriedForward Decimal  @db.Decimal(18, 2)
  deferredCapitalGoodsInputTax Decimal  @db.Decimal(18, 2)
  totalInputTaxAsset           Decimal  @db.Decimal(18, 2)
  computedAt                   DateTime
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // One booked asset per client + source form + period (re-send updates it).
  @@unique([clientId, sourceForm, asOfYear, asOfQuarter])
  @@index([clientId])
  @@map("input_tax_assets")
}

/// A firm's service-offering catalog (Portal-only; not part of the BIR contract).
/// Firm-scoped and managed by Firm/Super Admins. `linkedForm` is an optional
/// FormCode (@portal/shared) that associates the service with a BIR form.
model Service {
  id            String   @id @default(uuid()) @db.Uuid
  firmId        String   @db.Uuid
  name          String
  description   String   @default("")
  defaultFee    Decimal  @default(0) @db.Decimal(18, 2)
  billingMethod String // "Quarterly" | "Monthly" | "As Filing"
  linkedForm    String? // FormCode (@portal/shared) or null
  status        String   @default("Active") // "Active" | "Retired"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@map("services")
}

/// Per-client income-tax computation configuration (Portal MANAGEMENT ESTIMATE
/// only — NOT authoritative BIR tax; guardrail #1). Exactly one row per client.
/// `method` selects the regime ("graduated" | "flat" | "percentage" |
/// "simplified8"); `bracketsJson` holds the graduated schedule as an array of
/// { over, notOver, baseTax, rate }; `flatRate` is the single rate % used by the
/// non-graduated methods. When no row exists the API serves the TRAIN graduated
/// default without persisting it.
model TaxRule {
  id           String   @id @default(uuid()) @db.Uuid
  clientId     String   @unique @db.Uuid
  method       String // "graduated" | "flat" | "percentage" | "simplified8"
  flatRate     Decimal? @db.Decimal(6, 3) // single rate % for non-graduated methods
  bracketsJson Json     @default("[]") // [{ over, notOver, baseTax, rate }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("tax_rules")
}

/// A firm-issued invoice billed against a client (Portal-only engagement billing;
/// NOT part of the BIR contract). Firm-scoped: `number` is unique per firm. Amounts
/// are Decimal(18,2); `vat` is a 12% management estimate over `subtotal` and
/// `total = subtotal + vat`. Line items cascade with the invoice.
model Invoice {
  id          String   @id @default(uuid()) @db.Uuid
  firmId      String   @db.Uuid
  clientId    String   @db.Uuid
  number      String
  description String   @default("")
  issuedDate  DateTime @db.Date
  dueDate     DateTime @db.Date
  status      String   @default("Draft") // "Draft" | "Sent" | "Paid" | "Overdue"
  subtotal    Decimal  @db.Decimal(18, 2)
  vat         Decimal  @db.Decimal(18, 2)
  total       Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  firm      Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lineItems InvoiceLineItem[]

  @@unique([firmId, number])
  @@index([firmId])
  @@index([clientId])
  @@map("invoices")
}

/// A single billed line on an Invoice. `amount = qty * rate`; the parent invoice's
/// `subtotal` is the sum of these. Cascades on invoice delete.
model InvoiceLineItem {
  id          String  @id @default(uuid()) @db.Uuid
  invoiceId   String  @db.Uuid
  description String
  qty         Decimal @db.Decimal(12, 2)
  rate        Decimal @db.Decimal(18, 2)
  amount      Decimal @db.Decimal(18, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

// --- Financial Statement Creator (standalone module) -------------------------
// A self-contained FS workbench. It READS the live Chart of Accounts to validate
// every trial-balance account code and to drive statement roll-ups, but it is
// otherwise decoupled: firmId / accountCode / createdById are validated scalars,
// not Prisma foreign keys, so the module owns no relationships into Client,
// Firm, or ChartAccount. Balances are entered/imported per period (no client
// ledger wiring yet).

model FsReport {
  id                  String    @id @default(uuid()) @db.Uuid
  firmId              String    @db.Uuid
  // Entity facts (typed into the report — not pulled from a client profile yet).
  entityName          String
  secRegistrationNo   String?
  registeredAddress   String?
  businessDescription String?
  framework           String    @default("PFRS for Small Entities")
  functionalCurrency  String    @default("PHP")
  approvalDate        DateTime? @db.Date // BOD authorization for issue
  status              String    @default("draft") // "draft" | "final"
  createdById         String    @db.Uuid
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  periods     FsPeriod[]
  tbEntries   TrialBalanceEntry[]
  adjustments FsAdjustment[]
  notes       FsNote[]

  @@index([firmId])
  @@map("fs_reports")
}

/// Per-report customisation of the Notes to Financial Statements. Policy blocks
/// come from the framework's disclosure library (rendered with the report's
/// entity facts); a row here only exists when the accountant toggles or
/// overrides a block, or adds a free-text custom note.
model FsNote {
  id        String   @id @default(uuid()) @db.Uuid
  reportId  String   @db.Uuid
  kind      String // "policy" | "custom"
  /// Library block key for a policy override/toggle; null for a custom note.
  blockKey  String?
  included  Boolean  @default(true)
  title     String? // override/custom title (null = library default)
  body      String? // override/custom body (null = library default)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report FsReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, blockKey])
  @@index([reportId])
  @@map("fs_notes")
}

model FsPeriod {
  id         String   @id @default(uuid()) @db.Uuid
  reportId   String   @db.Uuid
  label      String // e.g. "2025"
  endDate    DateTime @db.Date
  periodType String   @default("FY") // "FY" | "Interim"
  sortOrder  Int // 0 = current period; higher = older comparative

  report    FsReport            @relation(fields: [reportId], references: [id], onDelete: Cascade)
  tbEntries TrialBalanceEntry[]

  @@unique([reportId, sortOrder])
  @@map("fs_periods")
}

model TrialBalanceEntry {
  id          String  @id @default(uuid()) @db.Uuid
  reportId    String  @db.Uuid
  periodId    String  @db.Uuid
  accountCode String // validated against chart_accounts at write time
  /// Period-end balance, SIGNED debit-positive (debit balance +, credit −);
  /// presentation flips sign per statement section.
  amount      Decimal @db.Decimal(18, 2)

  report FsReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  period FsPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([periodId, accountCode])
  @@index([reportId])
  @@map("trial_balance_entries")
}

model FsAdjustment {
  id        String   @id @default(uuid()) @db.Uuid
  reportId  String   @db.Uuid
  periodId  String   @db.Uuid // an adjustment applies to a single period
  memo      String   @default("")
  createdAt DateTime @default(now())

  report FsReport           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  lines  FsAdjustmentLine[]

  @@index([reportId])
  @@map("fs_adjustments")
}

model FsAdjustmentLine {
  id           String  @id @default(uuid()) @db.Uuid
  adjustmentId String  @db.Uuid
  accountCode  String // validated against chart_accounts at write time
  debit        Decimal @default(0) @db.Decimal(18, 2)
  credit       Decimal @default(0) @db.Decimal(18, 2)

  adjustment FsAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)

  @@index([adjustmentId])
  @@map("fs_adjustment_lines")
}
