# ---------------------------------------------------------------------------
# Accounting Firm Portal — environment template.
# Copy to `.env` (git-ignored) and fill in real values. NEVER commit secrets,
# and NEVER expose server secrets to the browser (guardrail #6).
# ---------------------------------------------------------------------------

# --- API (apps/api) --------------------------------------------------------
NODE_ENV=development
API_PORT=3000

# PostgreSQL — used by Prisma. Matches docker-compose.yml defaults.
DATABASE_URL=postgresql://portal:portal@localhost:5432/portal?schema=public

# Redis — queue + cache (BullMQ in later phases).
REDIS_URL=redis://localhost:6379

# Auth — JWT signing secret + token lifetimes. CHANGE THE SECRET in any real env.
JWT_SECRET=dev-insecure-secret-change-me
JWT_ACCESS_TTL=1h
JWT_MFA_TTL=5m

# OAuth2 client-credentials token lifetime (BIR Form Generator integration).
OAUTH_TOKEN_TTL=1h

# Client-user invitation link lifetime (hours). Default 7 days.
INVITE_TTL_HOURS=168

# Bootstrap Super Admin created by `pnpm --filter api db:seed`.
SEED_FIRM_NAME=Demo Accounting Firm
SEED_ADMIN_EMAIL=admin@firm.test
SEED_ADMIN_PASSWORD=ChangeMe123!

# Optional demo OAuth2 machine client for the BIR Form Generator. When BOTH are
# set, `db:seed` provisions an integration client with all scopes granted. Leave
# unset to skip (never seeds a machine credential with a default secret).
# SEED_INTEGRATION_CLIENT_KEY=bir-generator
# SEED_INTEGRATION_CLIENT_SECRET=change-me-long-random

# SSO sign-in (Google / Microsoft) — OPTIONAL. OIDC authorization-code flow;
# SSO only signs in EXISTING portal accounts (matched by email) — it is not a
# signup path. A provider's button appears on the login page only when its
# client id + secret AND API_PUBLIC_URL are set.
# Register these redirect URIs with the providers:
#   Google (console.cloud.google.com → OAuth client, type "Web application"):
#     <API_PUBLIC_URL>/api/v1/auth/sso/google/callback
#   Microsoft (portal.azure.com → App registrations → Web platform):
#     <API_PUBLIC_URL>/api/v1/auth/sso/microsoft/callback
# API_PUBLIC_URL=https://api.example.sliplane.app
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT=common

# Outbound email (invite / billing / notification emails) — OPTIONAL.
# Provider-agnostic: the sender is selected by MAIL_PROVIDER and swapped by
# config alone. Defaults to the firm's self-hosted Postal server.
#   postal → set POSTAL_API_KEY (Postal → Server → API credentials) and
#            POSTAL_API_URL (the full send endpoint). POSTAL_BASE_URL is an
#            alternative: a host that /api/v1/send/message is appended to.
#   plunk  → set MAIL_PROVIDER=plunk and PLUNK_SECRET_KEY.
# MAIL_FROM must be a sender the provider has verified (MAIL_FROM_EMAIL is an
# accepted legacy alias). When unset, invitations are still created but show
# "email failed" with a Resend button.
# MAIL_PROVIDER=postal
# MAIL_FROM=invites@mail.mcrctas.com
# MAIL_FROM_NAME="MCRC Tax & Accounting"
# POSTAL_API_KEY=
# POSTAL_API_URL=https://postal.sentire.solutions/api/v1/send/message
# PLUNK_SECRET_KEY=
# Public web-app origin used in the invite accept link (no trailing slash).
# WEB_APP_URL=https://acctgfirm.mcrctas.com

# MCP endpoint — OPTIONAL. Model Context Protocol server for connecting Claude
# (claude.ai / Cowork custom connector) at
#   POST <api-base>/api/v1/mcp/<secret>
# The secret is PORTAL-MANAGED: the Super Admin views/rotates/disables it on
# the Integrations page (stored in the firm's settings). This env var is only
# the pre-portal FALLBACK — once a secret has been rotated from the portal it
# is ignored and can be removed.
# Exposes 16 firm-scoped tools: 7 read (clients, invoices, transactions,
# financial summary, categories) + 9 write (create/update/archive clients,
# record/delete transactions, create/edit invoices + status). Writes run
# through the same service layer as the web UI and are audit-logged as
# "Claude (MCP)". Anyone with this URL can WRITE portal data — treat the
# secret as a password and rotate it to revoke access.
# Leave unset and the route answers 404 (feature off). Must be 32+ characters;
# generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# MCP_SHARED_SECRET=

# COR file storage — OPTIONAL. S3-compatible object storage (R2, MinIO, etc.)
# for uploaded BIR Certificate of Registration (COR) files. This is optional:
# leave these unset and the COR upload routes return 503 "COR storage not
# configured" (the rest of the app runs normally, and client-side COR OCR still
# works). Set ALL FOUR of endpoint/bucket/access-key/secret to enable it.
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_BUCKET=portal-cor
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto

# --- Web (apps/web) --------------------------------------------------------
# Only VITE_-prefixed vars are exposed to the browser bundle. Keep secrets out.
VITE_API_BASE_URL=http://localhost:3000/api/v1
